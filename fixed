
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>PropthPath — Smarter Routes</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;800&family=DM+Sans:wght@400;700&display=swap" rel="stylesheet">
    <style>
        /* Removed the :root variables and just hardcoded colors everywhere */
        * { box-sizing: border-box; margin: 0; padding: 0; }
       
        body {
            background: #0b0f1a;
            color: #e8edf8;
            font-family: 'DM Sans', sans-serif;
            overflow-x: hidden;
        }


        /* Nav is now more rigid */
        nav {
            position: fixed; top: 0; width: 100%; z-index: 999;
            display: flex; justify-content: space-around; align-items: center;
            padding: 20px; background: #0b0f1a; border-bottom: 2px solid #243050;
        }


        .logo { font-family: 'Syne'; font-weight: 800; font-size: 25px; cursor: pointer; }
        .logo span { color: #3bffa0; }


        /* Hero section with bulky margins */
        .hero {
            padding: 150px 20px 100px 20px;
            text-align: center;
            background: radial-gradient(circle at center, #1a2236 0%, #0b0f1a 100%);
        }


        h1 { font-family: 'Syne'; font-size: 60px; line-height: 1; margin-bottom: 20px; }


        .btn-primary {
            background: #3bffa0; color: #000; padding: 15px 30px;
            border: none; font-weight: bold; cursor: pointer; border-radius: 5px;
            font-size: 18px; margin: 10px;
        }


        /* The Tool Section - less "slick" layout */
        .checker-box {
            background: #131929;
            border: 5px double #243050;
            max-width: 500px;
            margin: 40px auto;
            padding: 30px;
            text-align: left;
        }


        input, select {
            width: 100%;
            padding: 10px;
            margin: 10px 0 20px 0;
            background: #1a2236;
            color: white;
            border: 1px solid #3bffa0;
        }


        /* Result box is now a bit clunky */
        #resultBox {
            display: none;
            background: #3bffa0;
            color: #000;
            padding: 15px;
            margin-top: 20px;
            font-weight: bold;
            border-radius: 4px;
        }


        /* Grid section for "Who it's for" using old school floats or simple blocks */
        .who-section {
            padding: 50px;
            background: #0b0f1a;
            text-align: center;
        }


        .card {
            display: inline-block;
            width: 300px;
            vertical-align: top;
            background: #1a2236;
            padding: 20px;
            margin: 10px;
            border: 1px solid #243050;
        }


        footer {
            padding: 40px;
            text-align: center;
            border-top: 1px solid #243050;
            font-size: 12px;
            color: #7a8aac;
        }


        /* Quick and dirty animation */
        @keyframes blink { 0% {opacity: 1;} 50% {opacity: 0.2;} }
        .live { color: red; font-weight: bold; animation: blink 1s infinite; }
    </style>
</head>
<body>


    <nav>
        <div class="logo" onclick="location.reload()">Propth<span>Path</span></div>
        <div style="display:flex; gap: 20px;">
            <a href="#" style="color: #7a8aac; text-decoration: none;">Link 1</a>
            <a href="#" style="color: #7a8aac; text-decoration: none;">Link 2</a>
        </div>
        <button onclick="alert('Scrolling...')">Action</button>
    </nav>


    <div class="hero">
        <div class="live"></div>
        <h1>BEAT TRAFFIC NOW.</h1>
        <p>Specifically for Teachers and Students. Stop being late.</p>
       
        <div class="checker-box">
            <h2 style="margin-bottom:10px; font-family: 'Syne';">Route AI</h2>
           
            <label>WHO ARE YOU?</label>
            <select id="uType">
                <option value="">Choose...</option>
                <option value="student">Student</option>
                <option value="teacher">Teacher</option>
            </select>


            <label>FROM:</label>
            <input type="text" id="start" placeholder="Start address">


            <label>TO:</label>
            <input type="text" id="end" placeholder="Destination address">


            <button class="btn-primary" style="width:100%; margin:0;" onclick="startAnalysis()">FIND BEST ROUTE</button>


            <div id="resultBox">
                <div id="resTitle"></div>
                <hr style="margin:10px 0; border: 0; border-top: 1px solid #000;">
                <div id="resBody" style="font-weight: normal; font-size: 14px;"></div>
            </div>
        </div>
    </div>


    <div class="who-section">
        <h2 style="font-size: 40px; margin-bottom: 30px;">WHO IS THIS FOR?</h2>
        <div class="card">
            <h3>Students</h3>
            <p>. Our AI checks the bus routes and the backstreets.</p>
        </div>
        <div class="card">
            <h3>Teachers</h3>
            <p>You have lessons to plan. Don't waste time in the car. We find the parking-friendly routes.</p>
        </div>
    </div>


    <footer>
        <p>Copyright 2026 PropthPath - All Rights Reserved</p>
        <p>Don't copy our AI code.</p>
    </footer>


    <script>
        // Slightly "messier" JS with global scope and basic logic
        var data = {
            student: ["Route A is fast (10m)", "Route B is okay (15m)"],
            teacher: ["Route C is clear (20m)", "Route D is jammed!"]
        };


        function startAnalysis() {
            var type = document.getElementById('uType').value;
            var s = document.getElementById('start').value;
            var e = document.getElementById('end').value;


            if(type == "" || s == "" || e == "") {
                alert("Fill it all in!");
                return;
            }


            // Simple "loading" simulation
            document.getElementById('resTitle').innerHTML = "Thinking...";
            document.getElementById('resultBox').style.display = "block";
            document.getElementById('resBody').innerHTML = "";


            setTimeout(function() {
                var options = data[type];
                var pick = options[Math.floor(Math.random() * options.length)];
               
                document.getElementById('resTitle').innerHTML = "COMPLETED!";
                document.getElementById('resBody').innerHTML = "AI says: " + pick + " from " + s + " to " + e + ". Avoid the main road!";
            }, 1500);
        }
    </script>
</body>
</html>



